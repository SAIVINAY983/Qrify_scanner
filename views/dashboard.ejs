<%- include('layout.ejs', { body: ` <div class="dashboard-header">
    <h2>Your QR Codes</h2>
    <a href="/qr/generate" class="btn btn-primary">Generate New</a>
    </div>

    <div class="qr-grid">
        ${qrcodes.length === 0 ? '<p>You have not generated any QR codes yet.</p>' : ''}
        ${qrcodes.map(qr => `
        <div class="qr-card">
            <img src="${qr.qrImage}" alt="QR Code">
            <div class="qr-info">
                <span class="qr-badge">${qr.type}</span>
                <p class="qr-content" title="${qr.content}">${qr.content.length > 30 ? qr.content.substring(0, 30) +
                    '...' : qr.content}</p>
                <small class="qr-date">${new Date(qr.createdAt).toLocaleDateString()}</small>
            </div>
            <div style="display: flex; gap: 0.75rem; justify-content: center; margin-top: auto;">
                <a href="${qr.qrImage}" download="qr-${qr.type}.png" class="btn btn-secondary btn-sm"
                    style="flex: 1;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.25rem;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>Download</a>
                <form action="/qr/delete/${qr._id}" method="POST" style="flex: 1; display: flex;"
                    onsubmit="return confirm('Delete this QR code?');">
                    <button type="submit" class="btn btn-danger btn-sm" style="width: 100%;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.25rem;"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>Delete</button>
                </form>
            </div>
        </div>
        `).join('')}
    </div>
    ` }) %>