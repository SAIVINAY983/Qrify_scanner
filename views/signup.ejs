<%- include('layout.ejs', { body: ` <div class="auth-box">
    <h2>Create an Account</h2>
    ${typeof error !== 'undefined' && error ? '<div class="alert alert-error">' + error + '</div>' : ''}
    <form action="/auth/signup" method="POST">
        <div class="form-group">
            <label for="username">Username</label>
            <input type="text" id="username" name="username" required placeholder="Choose a username">
        </div>
        <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required placeholder="Enter your email">
        </div>
        <div class="form-group">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" required placeholder="Choose a secure password">
        </div>
        <button type="submit" class="btn btn-primary btn-block">Sign Up</button>
    </form>
    <p class="auth-link">Already have an account? <a href="/login">Login here</a></p>
    </div>
    ` }) %>